# ══════════════════════════════════════════════════════════════════════════════
# Argus — non-secret configuration
#
# SECRETS (API keys, passwords, tokens) are stored in the OS keychain.
# Run `argus-setup` once to populate them securely.
# Do NOT add secrets to this file.
# ══════════════════════════════════════════════════════════════════════════════

# ── Robinhood ──────────────────────────────────────────────────────────────────
ROBINHOOD_USERNAME=your_email@example.com
# ROBINHOOD_PASSWORD and ROBINHOOD_MFA_SECRET → stored via `argus-setup`

# Account numbers (from Robinhood → Settings → Account)
AGENTIC_ACCOUNT_NUMBER=your_agentic_account_number
DEFAULT_ACCOUNT_NUMBER=your_default_account_number

# ── Trading mode ───────────────────────────────────────────────────────────────
# Set to "false" for live trading (use with caution!)
PAPER_TRADE=true

# Minimum risk level requiring approval on the default account: "medium" or "high"
APPROVAL_THRESHOLD=medium

# ── Watchlist ──────────────────────────────────────────────────────────────────
WATCHLIST=AAPL,TSLA,NVDA,BTC,ETH

# ── Risk guardrails ────────────────────────────────────────────────────────────
MAX_POSITION_PCT=0.10
STOP_LOSS_PCT=0.05
MAX_POSITIONS=5
DAILY_DRAWDOWN_LIMIT=-0.05

# ── Loop interval ──────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=300

# ── Notifications (non-secret settings) ───────────────────────────────────────
NOTIFY_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
# SMTP_PASSWORD → stored via `argus-setup`

TWILIO_ACCOUNT_SID=
TWILIO_FROM=+1XXXXXXXXXX
TWILIO_TO=+1XXXXXXXXXX
# TWILIO_AUTH_TOKEN → stored via `argus-setup`

SLACK_CHANNEL=#argus-alerts
# SLACK_BOT_TOKEN → stored via `argus-setup`

# ── Web dashboard ──────────────────────────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=8000

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///argus.db
