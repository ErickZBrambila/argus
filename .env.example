# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY_HERE

# ── Robinhood ──────────────────────────────────────────────────────────────────
ROBINHOOD_USERNAME=your@email.com
ROBINHOOD_PASSWORD=yourpassword
# Optional: Robinhood MFA secret (base32) for TOTP-based 2FA
ROBINHOOD_MFA_SECRET=

# ── Trading mode ───────────────────────────────────────────────────────────────
# Set to "true" to run in paper trading mode (no real orders placed)
PAPER_TRADE=true

# ── Watchlist ──────────────────────────────────────────────────────────────────
# Comma-separated list of symbols to trade
WATCHLIST=AAPL,TSLA,NVDA,BTC,ETH

# ── Risk guardrails ────────────────────────────────────────────────────────────
MAX_POSITION_PCT=0.10          # Max 10% of portfolio per position
STOP_LOSS_PCT=0.05             # Stop-loss at 5% below entry
MAX_POSITIONS=5                # Max concurrent positions
DAILY_DRAWDOWN_LIMIT=-0.05     # Halt trading at -5% daily P&L

# ── Loop interval ──────────────────────────────────────────────────────────────
SCAN_INTERVAL_SECONDS=300      # How often to run the scan loop (default 5 min)

# ── Notifications ──────────────────────────────────────────────────────────────
# Email (SMTP)
NOTIFY_EMAIL=                  # Recipient email (leave blank to disable)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# SMS via Twilio (leave blank to disable)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=+1XXXXXXXXXX
TWILIO_TO=+1XXXXXXXXXX

# Slack (leave blank to disable)
SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN_HERE
SLACK_CHANNEL=#argus-alerts

# ── Web dashboard ──────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8000

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///argus.db
